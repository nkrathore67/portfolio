---
import { site, navLinks } from '../data/content';
const base = import.meta.env.BASE_URL;
---
<header>
  <a href={base} class="logo">{site.title}</a>
  <button class="menu-btn" aria-label="Open navigation" aria-expanded="false" aria-controls="primary-nav">
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav id="primary-nav" aria-label="Main">
    <ul>
      {navLinks.map((link) => (
        <li><a href={`${base}${link.href}`}>{link.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const btn = document.querySelector('.menu-btn') as HTMLButtonElement | null;
  const nav = document.getElementById('primary-nav');

  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    btn.classList.toggle('open', !open);
    nav?.classList.toggle('open', !open);
  });

  nav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      btn?.classList.remove('open');
      nav?.classList.remove('open');
    });
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.75rem clamp(1rem, 4vw, 2rem);
    background: var(--bg-elevated);
    border-bottom: 2px solid var(--accent-1);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .logo {
    font-family: var(--font-pixel);
    font-size: clamp(0.45rem, 1.6vw, 0.8rem);
    color: var(--accent-1);
    text-shadow: var(--glow-1);
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo:hover { text-decoration: none; filter: brightness(1.2); }

  /* ── Hamburger (desktop: hidden) ── */
  .menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 0.4rem 0.5rem;
    background: transparent;
    border: 1px solid var(--accent-1);
    cursor: pointer;
    flex-shrink: 0;
  }
  .menu-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--accent-1);
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .menu-btn.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-btn.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .menu-btn.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.4rem, 1.8vw, 1.5rem);
    list-style: none;
  }

  nav a {
    font-family: var(--font-retro);
    font-size: clamp(0.95rem, 2.2vw, 1.25rem);
    color: var(--text);
    transition: color 0.2s, text-shadow 0.2s;
  }
  nav a:hover {
    color: var(--accent-2);
    text-shadow: var(--glow-2);
    text-decoration: none;
  }

  /* ── Mobile ≤ 640px ── */
  @media (max-width: 640px) {
    header { padding: 0.6rem 1rem; }
    .menu-btn { display: flex; }

    nav {
      width: 100%;
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.3s ease;
      border-top: 0px solid var(--accent-3);
    }
    nav.open {
      max-height: 500px;
      border-top-width: 1px;
    }
    nav ul {
      flex-direction: column;
      gap: 0;
      padding: 0.4rem 0;
    }
    nav a {
      display: block;
      padding: 0.65rem 0.25rem;
      font-size: 1.5rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    nav li:last-child a { border-bottom: none; }
  }

  /* ── Tablet 641–900px: tighten spacing ── */
  @media (min-width: 641px) and (max-width: 900px) {
    nav a { font-size: 1.05rem; }
  }
</style>
