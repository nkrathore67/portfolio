---
import Header from './Header.astro';
import { site, footer } from '../data/content';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = 'Personal portfolio — what I do, what I like, my background.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="crt-overlay">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <footer>
      <p class="footer-line">{footer.line}</p>
      <p class="footer-copy"><slot name="footer">{footer.copyright}</slot></p>
    </footer>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    padding: 0.75rem 1rem;
    background: var(--accent-1);
    color: var(--bg);
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    z-index: 10000;
    transition: top 0.2s;
  }

  .skip-link:focus {
    top: 0;
    outline: none;
  }

  main {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 2rem);
  }

  footer {
    margin-top: 4rem;
    padding: var(--section-padding) clamp(1rem, 4vw, 2rem);
    border-top: 2px solid var(--accent-3);
    text-align: center;
    color: var(--text-muted);
    font-family: var(--font-retro);
    font-size: 1.1rem;
  }

  .footer-line {
    margin-bottom: 0.5rem;
    color: var(--accent-3);
  }

  .footer-copy {
    font-size: 0.9rem;
    font-family: var(--font-body);
  }
</style>
