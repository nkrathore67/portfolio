---
import Section from './Section.astro';
import { skills } from '../data/content';
---
<Section id="what-i-do" title="Stats">
  <p class="stats-intro">Skill tree — languages and tools I use.</p>
  <ul class="stats-list" aria-label="Skills">
    {skills.map((skill) => (
      <li class="stat-item">
        <span class="stat-name">{skill.name}</span>
        <div class="stat-bar" role="presentation">
          <span class="stat-fill" style={`width: ${skill.level}%`} />
        </div>
        <span class="stat-value">{skill.level}%</span>
      </li>
    ))}
  </ul>
</Section>

<style>
  .stats-intro {
    margin-bottom: 1.5rem;
    color: var(--text-muted);
  }

  .stats-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stat-item {
    display: grid;
    grid-template-columns: 120px 1fr 3ch;
    align-items: center;
    gap: 1rem;
  }

  .stat-name {
    font-family: var(--font-retro);
    font-size: 1.2rem;
    color: var(--accent-4);
  }

  .stat-bar {
    height: 12px;
    background: var(--bg-elevated);
    border: 1px solid var(--accent-3);
    border-radius: 2px;
    overflow: hidden;
  }

  .stat-fill {
    display: block;
    height: 100%;
    background: linear-gradient(90deg, var(--accent-3), var(--accent-1));
    transition: width 0.5s ease;
  }

  .stat-value {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--text-muted);
  }

  @media (max-width: 500px) {
    .stat-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .stat-value {
      grid-column: 1;
    }
  }
</style>
