---
import Section from './Section.astro';
import { experience } from '../data/content';
---
<Section id="experience" title="Work Experience">
  <ul class="exp-list">
    {experience.map((job) => (
      <li class="exp-item">
        <div class="exp-header">
          <span class="exp-role">{job.role}</span>
          <span class="exp-company">{job.company} — {job.location}</span>
          <span class="exp-period">{job.period}</span>
        </div>
        <ul class="exp-bullets">
          {job.bullets.map((b) => (
            <li>{b}</li>
          ))}
        </ul>
      </li>
    ))}
  </ul>
</Section>

<style>
  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .exp-item {
    border-left: 2px solid var(--accent-2);
    padding-left: 1.25rem;
  }

  .exp-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1rem;
    margin-bottom: 0.75rem;
  }

  .exp-role {
    font-family: var(--font-retro);
    font-size: 1.2rem;
    color: var(--accent-1);
  }

  .exp-company {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .exp-period {
    margin-left: auto;
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--accent-4);
    white-space: nowrap;
  }

  .exp-bullets {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .exp-bullets li {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  @media (max-width: 520px) {
    .exp-item { padding-left: 0.875rem; }

    .exp-period {
      margin-left: 0;
      width: 100%;
    }

    .exp-bullets { padding-left: 1rem; }
    .exp-bullets li { font-size: 0.9rem; }
  }
</style>
