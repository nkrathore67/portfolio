---
import Section from './Section.astro';
import { projects } from '../data/content';
---
<Section id="projects" title="Quest log">
  <p class="quest-intro">Projects and things I've shipped (or am building).</p>
  <ul class="quest-list">
    {projects.map((p) => (
      <li class="quest-card">
        <a href={p.href} class="quest-link">
          <h3>{p.title}</h3>
          <p>{p.description}</p>
          <ul class="quest-tags" aria-label="Technologies">
            {p.tags.map((tag) => (
              <li><span class="tag">{tag}</span></li>
            ))}
          </ul>
        </a>
      </li>
    ))}
  </ul>
</Section>

<style>
  .quest-intro {
    margin-bottom: 1.5rem;
    color: var(--text-muted);
  }

  .quest-list {
    list-style: none;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  .quest-card {
    border: 1px solid var(--accent-2);
    border-radius: 4px;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .quest-link {
    display: block;
    padding: 1.25rem;
    color: inherit;
  }

  .quest-link:hover {
    text-decoration: none;
  }

  .quest-card:hover {
    border-color: var(--accent-1);
    box-shadow: var(--glow-1);
  }

  .quest-card h3 {
    margin-bottom: 0.5rem;
  }

  .quest-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .quest-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }

  .tag {
    font-family: var(--font-retro);
    font-size: 0.9rem;
    padding: 0.2rem 0.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--accent-4);
    border-radius: 2px;
    color: var(--accent-4);
  }
</style>
