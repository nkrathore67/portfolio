import WhatIDo from '../components/WhatIDo.astro';
import HobbiesInterests from '../components/HobbiesInterests.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import { footer } from '../data/content';
---
<Layout title="Portfolio — Developer · Gamer · Creator">
  <Hero />
  <About />
  <WhatIDo />
  <HobbiesInterests />
  <Projects />
  <Contact />
  <Fragment slot="footer">{footer.copyright}</Fragment>
